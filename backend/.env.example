# Application settings
APP_NAME=Tarımcık API
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tarimcik
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/tarimcik

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage (S3 compatible or local)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_REGION=

# AI Services
# OPENAI_API_KEY=
# HUGGINGFACE_API_KEY=
AI_MODEL_PATH=./ai/models

# Redis (for caching and Celery)
REDIS_URL=redis://localhost:6379/0
